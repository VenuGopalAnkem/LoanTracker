@model System.Data.DataTable

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Loans</h2>

<a href="/Loan/CreateLoan" class="btn btn-primary mb-3">
    Create Loan
</a>

<table class="table table-bordered">

    <thead>

        <tr>

            <th>Borrower</th>
            <th>Loan</th>
            <th>Daily Pay</th>
            <th>Total Paid</th>
            <th>Balance</th>
            <th>Progress</th>

        </tr>

    </thead>

    <tbody>

        @foreach (System.Data.DataRow r in Model.Rows)
        {

            decimal loan = Convert.ToDecimal(r["LoanAmount"]);

            decimal paid = Convert.ToDecimal(r["TotalPaid"]);

            decimal progress = (paid / loan) * 100;

            <tr>

                <td>@r["FullName"]</td>

                <td>@loan</td>

                <td>@r["DailyPay"]</td>

                <td>@paid</td>

                <td>@r["Balance"]</td>

                <td>

                    <div class="progress">

                        <div class="progress-bar bg-success"
                             style="width:@progress%">

                            @progress %

                        </div>

                    </div>

                </td>

            </tr>

        }

    </tbody>

</table>