@model System.Data.DataTable

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h3 class="mb-4 fw-bold text-primary">Daily Collection</h3>

    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Borrower</th>
                        <th>Loan</th>
                        <th>Daily Pay</th>
                        <th>Total Paid</th>
                        <th>Balance</th>
                        <th>Collect</th>
                        <th>Receipt</th>
                        <th>History</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (System.Data.DataRow r in Model.Rows)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @r["FullName"]
                            </td>

                            <td>
                                ₹ @r["LoanAmount"]
                            </td>

                            <td class="text-success fw-bold">
                                ₹ @r["DailyPay"]
                            </td>

                            <td>
                                ₹ @r["TotalPaid"]
                            </td>

                            <td class="text-danger fw-bold">
                                ₹ @r["Balance"]
                            </td>

                            <!-- Collect -->

                            <td>

                                <form method="post" action="/Loan/Collect">

                                    <input type="hidden"
                                           name="LoanId"
                                           value="@r["LoanId"]" />

                                    <div class="input-group">

                                        <input type="number"
                                               name="Amount"
                                               value="@r["DailyPay"]"
                                               class="form-control" />

                                        <button class="btn btn-success">
                                            Collect
                                        </button>

                                    </div>

                                </form>

                            </td>

                            <!-- Receipt -->

                            <td>

                                <button class="btn btn-primary btn-sm"
                                        onclick="openReceipt('@r["LoanId"]')">
                                   
                                    View Receipt

                                </button>

                            </td>

                            <td>
                            <button class="btn btn-info btn-sm"
                                    onclick="openHistory(@r["LoanId"])">

                                History

                            </button>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>


<!-- Receipt Modal -->

<div class="modal fade"
     id="receiptModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content rounded-4">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    Payment Receipt
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body p-0">

                <iframe id="receiptFrame"
                        style="width:100%; height:500px; border:none;">
                </iframe>

            </div>

        </div>

    </div>

</div>


<div class="modal fade" id="historyModal">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Payment History
                </h5>

                <button class="btn-close" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body" id="historyContent">

                Loading...

            </div>

        </div>

    </div>

</div>


<script>

      function openReceipt(LoanId) {

        var url = "/Receipt/ViewReceipt?LoanId=" + LoanId;

        document.getElementById("receiptFrame").src = url;

        var modal = new bootstrap.Modal(
            document.getElementById("receiptModal")
        );

        modal.show();
    }


    function openHistory(loanId){

    $.get("/Loan/PaymentHistory?loanId="+loanId,function(data){

    $("#historyContent").html(data);

    $("#historyModal").modal("show");

    });

    }
</script>