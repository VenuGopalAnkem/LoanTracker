@model System.Data.DataTable

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* 27042025 *@
<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold text-primary">Daily Collection</h3>
            <span class="text-muted">Manage today's payments</span>
        </div>

        <div class="text-end">

            <input type="text"
                   id="searchBorrower"
                   class="form-control"
                   placeholder="Search borrower..."
                   style="width:250px">

        </div>

    </div>

    <!-- Summary -->

    <div class="row mb-4">

        <div class="col-md-3">

            <div class="card dashboard-card text-center p-3">

                <h6 class="text-muted">Total Loans</h6>

                <h3 class="fw-bold text-primary">
                    @Model.Rows.Count
                </h3>

            </div>

        </div>

    </div>

    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>
                            <th>Borrower</th>
                            <th>Loan</th>
                            <th>Daily Pay</th>
                            <th>Total Paid</th>
                            <th>Balance</th>
                            <th>Collect</th>
                            <th>Receipt</th>
                            <th>History</th>
                        </tr>

                    </thead>

                    <tbody id="collectionTable">

                        @foreach (System.Data.DataRow r in Model.Rows)
                        {
                            <tr>

                                <!-- Borrower -->

                                <td>

                                    <div class="d-flex align-items-center">

                                        <div class="avatar-circle me-2">
                                            <i class="bi bi-person-fill"></i>
                                        </div>

                                        <span class="fw-semibold">
                                            @r["FullName"]
                                        </span>

                                    </div>

                                </td>

                                <!-- Loan -->

                                <td class="fw-semibold">
                                    ₹ @r["LoanAmount"]
                                </td>

                                <!-- Daily -->

                                <td>
                                    <span class="badge bg-success p-2">
                                        ₹ @r["DailyPay"]
                                    </span>
                                </td>

                                <!-- Paid -->

                                <td>
                                    ₹ @r["TotalPaid"]
                                </td>

                                <!-- Balance -->

                                <td>

                                    <span class="badge bg-danger p-2">
                                        ₹ @r["Balance"]
                                    </span>

                                </td>

                                <!-- Collect -->

                                <td>

                                    <form method="post" action="/Loan/Collect">

                                        <input type="hidden"
                                               name="LoanId"
                                               value="@r["LoanId"]" />

                                        <div class="input-group input-group-sm">

                                            <input type="number"
                                                   name="Amount"
                                                   value="@r["DailyPay"]"
                                                   class="form-control" />

                                            <button class="btn btn-success">
                                                Collect
                                            </button>

                                        </div>

                                    </form>

                                </td>

                                <!-- Receiptt -->

                                <td>

                                    <button class="btn btn-primary btn-sm"
                                            onclick="openReceipt('@r["LoanId"]')">

                                        <i class="bi bi-receipt"></i>

                                    </button>

                                </td>

                                <!-- History -->

                                <td>

                                    <button class="btn btn-info btn-sm"
                                            onclick="openHistory(@r["LoanId"])">

                                        <i class="bi bi-clock-history"></i>

                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script>

      function openReceipt(LoanId) {

        var url = "/Receipt/ViewReceipt?LoanId=" + LoanId;

        document.getElementById("receiptFrame").src = url;

        var modal = new bootstrap.Modal(
            document.getElementById("receiptModal")
        );

        modal.show();
      }


    function openHistory(loanId){

    $.get("/Loan/PaymentHistory?loanId="+loanId,function(data){

    $("#historyContent").html(data);

    $("#historyModal").modal("show");

    });

    }


        document.getElementById("searchBorrower").addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        let rows = document.querySelectorAll("#collectionTable tr");

        rows.forEach(function (row) {

            let text = row.innerText.toLowerCase();

            row.style.display = text.includes(value) ? "" : "none";

        });

    });
</script>