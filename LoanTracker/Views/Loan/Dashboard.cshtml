@model LoanTracker.Models.DashboardModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* 27042025 *@
<div class="container-fluid mt-4">

    <div class="dashboard-header text-center mb-5">
        <h2 class="fw-bold">Loan Tracker Dashboard</h2>
        <p class="text-muted">Financial overview of your system</p>
    </div>

    <div class="row g-4">
        <!-- Borrowers -->
        <!-- Borrowers -->
        <div class="col-lg-4">
            <div class="dashboard-card borrowers">

                <div class="card-icon">
                    <i class="bi bi-people-fill"></i>
                </div>

                <div class="card-content">

                    <h6>Total Borrowers</h6>

                    <h2>@Model.TotalBorrowers</h2>

                    <span class="small-text">Registered users</span>

                </div>

            </div>
        </div>


        <!-- Loans -->
        <div class="col-lg-4">
            <div class="dashboard-card loans">

                <div class="card-icon">
                    <i class="bi bi-cash-stack"></i>
                </div>

                <div class="card-content">

                    <h6>Total Loans</h6>

                    <h2>@Model.TotalLoans</h2>

                    <span class="small-text">Active loans issued</span>

                </div>

            </div>
        </div>


        <!-- Pending Balance -->
        <div class="col-lg-4">
            <div class="dashboard-card pending">

                <div class="card-icon">
                    <i class="bi bi-exclamation-circle-fill"></i>
                </div>

                <div class="card-content">

                    <h6>Pending Balance</h6>

                    <h2>₹ @Model.PendingBalance</h2>

                    <span class="small-text">Amount yet to collect</span>

                </div>

            </div>
        </div>

    </div>

</div>