@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Create Loan</h2>

<form method="post" action="/Loan/SaveLoan">

    <div class="row">

        <div class="col-md-4">

            <label>Borrower</label>

            <select name="BorrowerId" class="form-control">

                @foreach (System.Data.DataRow b in ViewBag.Borrowers.Rows)
                {
                    <option value="@b["Id"]">@b["FullName"]</option>
                }

            </select>

        </div>

        <div class="col-md-4">

            <label>Loan Amount</label>

            <input id="LoanAmount" name="LoanAmount" class="form-control" />

        </div>

        <div class="col-md-4">

            <label>Commission %</label>

            <input id="CommissionPercent" name="CommissionPercent" class="form-control" />

        </div>

        <div class="col-md-4 mt-3">

            <label>Loan Period (Days)</label>

            <input name="LoanPeriod" value="100" class="form-control" />

        </div>

        <div class="col-md-6 mt-3">

            <label>Loan Purpose</label>

            <input name="LoanPurpose" class="form-control" />

        </div>

    </div>

    <button class="btn btn-primary mt-4">
        Save Loan
    </button>

</form>

<script>

    function calculateLoan(){

    var loan=parseFloat(document.getElementById("LoanAmount").value)||0;

    var commission=parseFloat(document.getElementById("CommissionPercent").value)||0;

    var commissionAmount=(loan*commission)/100;

    var finalLoan=loan-commissionAmount;

    var dailyPay=loan/100;

    console.log("Commission:",commissionAmount);

    }

    document.getElementById("LoanAmount").addEventListener("keyup",calculateLoan);

    document.getElementById("CommissionPercent").addEventListener("keyup",calculateLoan);

</script>